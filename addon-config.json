{
  "metadata": {
    "id": "reddawn-main-2026",
    "name": "RED DAWN - Multi-Source Streaming (FREE + PREMIUM)",
    "description": "Advanced streaming addon featuring:\n• Free torrents (P2P)\n• Premium Debrid services (RealDebrid, Premiumize, AllDebrid)\n• Usenet sources\n• HTTP sources\n• Original language audio\n• Best quality streams\n• HDR/DolbyVision support\n• Atmos/TrueHD/DTS-HD audio\n• Both cached & uncached streams",
    "source": "external",
    "author": "Dave + Red Dawn Team",
    "version": "1.1.0",
    "category": "Multi-Source Debrid"
  },
  "config": {
    "trusted": false,
    "showChanges": true,
    "addonName": "Red Dawn Streaming",
    "addonLogo": "https://raw.githubusercontent.com/Tre9995/reddawn-addon/main/logo/reddawn.png",
    "addonDescription": "Professional multi-source streaming with Tamtaro SEL filtering v2.6.1 and Vidhin's regex patterns",
    "appliedTemplates": [
      {
        "id": "tamtaro.complete",
        "version": "2.6.1",
        "url": "https://raw.githubusercontent.com/Tam-Taro/SEL-Filtering-and-Sorting/refs/heads/main/Tamtaro-All-Templates-for-AIOStreams.json"
      }
    ],
    "preferredResolutions": [
      "2160p",
      "1440p",
      "1080p",
      "720p"
    ],
    "preferredQualities": [
      "BluRay REMUX",
      "BluRay",
      "WEB-DL",
      "WEBRip",
      "HDRip",
      "HC HD-Rip",
      "DVDRip",
      "HDTV",
      "SCR",
      "TC",
      "TS",
      "CAM"
    ],
    "requiredLanguages": [
      "English",
      "Spanish",
      "Latino",
      "Original",
      "Dual Audio",
      "Multi",
      "Dubbed"
    ],
    "preferredLanguages": [
      "Original",
      "English",
      "Spanish",
      "Latino",
      "Dual Audio",
      "Multi"
    ],
    "preferredSubtitles": [
      "English",
      "Spanish",
      "All"
    ],
    "excludedVisualTags": [
      "3D",
      "H-OU",
      "H-SBS"
    ],
    "preferredVisualTags": [
      "HDR+DV",
      "DV",
      "HDR10+",
      "HDR10",
      "HDR",
      "10bit",
      "IMAX"
    ],
    "preferredAudioTags": [
      "Atmos",
      "DTS:X",
      "TrueHD",
      "DTS-HD MA",
      "FLAC",
      "DTS-HD",
      "DTS-ES",
      "DTS",
      "DD+",
      "DD"
    ],
    "preferredStreamTypes": [
      "debrid",
      "usenet",
      "p2p",
      "http"
    ],
    "preferredEncodes": [
      "AV1",
      "HEVC",
      "AVC"
    ],
    "excludedKeywords": [
      "IMAX",
      "Open Matte",
      "Expanded Ratio",
      "Extended",
      "Extended Cut",
      "Director's cut",
      "Special Edition",
      "Ultimate edition",
      "Collector's edition",
      "Unrated",
      "Roadshow",
      "Redux",
      "Final cut"
    ],
    "enableSeadex": true,
    "excludeUncached": false,
    "sortCriteria": {
      "global": [
        {
          "key": "cached",
          "direction": "desc"
        }
      ],
      "cached": [
        {
          "key": "size",
          "direction": "desc"
        },
        {
          "key": "seadex",
          "direction": "desc"
        },
        {
          "key": "resolution",
          "direction": "desc"
        },
        {
          "key": "quality",
          "direction": "desc"
        },
        {
          "key": "language",
          "direction": "desc"
        },
        {
          "key": "audioTag",
          "direction": "desc"
        },
        {
          "key": "visualTag",
          "direction": "desc"
        },
        {
          "key": "seeders",
          "direction": "desc"
        }
      ],
      "uncached": [
        {
          "key": "seadex",
          "direction": "desc"
        },
        {
          "key": "resolution",
          "direction": "desc"
        },
        {
          "key": "quality",
          "direction": "desc"
        },
        {
          "key": "seeders",
          "direction": "desc"
        },
        {
          "key": "language",
          "direction": "desc"
        }
      ]
    },
    "posterService": "rpdb",
    "usePosterRedirectApi": true,
    "formatter": {
      "id": "custom",
      "definitions": {
        "custom": {
          "name": "{stream.resolution::exists[\"{stream.resolution::replace('2160p','🔥 4K UHD')::replace('1440p','✨ QHD')::replace('1080p','🚀 Full HD')::replace('720p','💿 HD')::replace('576p','📺 SD')}\"]}",
          "description": "{stream.title::exists[\"🎬 {stream.title::title} \"||\"\"]}{stream.year::exists[\" ({stream.year})\"||\"\"]}\n{stream.formattedSeasons::exists[\"📺 {stream.formattedSeasons}\"||\"\"]}"
        }
      }
    }
  }
}
